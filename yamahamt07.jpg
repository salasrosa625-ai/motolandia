.pa_energyRating span { vertical-align: middle; font-size: 13px; color: rgb=
(102, 102, 102); }

.pa_energyRating .ciptr { margin-left: 4px; }

.pa_energyRating { overflow: hidden; text-overflow: ellipsis; white-space: =
nowrap; }

.pa_energyRating .energy_rating { display: flex; }

.pa_energyRating .energy_rating .b_energybg { margin-left: 4px; }

.vsp_ads .richImage .mainContainer { overflow: hidden; }

.vsp_ads .richImage { overflow: hidden; }

.vsp_ads .richImage img { transition: 0.3s ease-out; }

.vsp_ads .richImage:hover img { transform: scale(1.1); }

.vsp_ads .richImage .captionContainer .cba { background-color: rgb(0, 61, 1=
91); color: rgb(255, 255, 255); margin-right: 8px; display: inline-block; p=
osition: relative; padding-left: 3px; font: 11px/11px var(--bing-smtc-text-=
style-default-regular-font-family); }

.vsp_ads .richImage .captionContainer .cba::after { display: inline-block; =
position: absolute; top: 0px; left: 100%; border-width: 5px 0px 5px 5px; bo=
rder-left-color: rgb(0, 61, 191); border-style: solid; content: ""; width: =
6px; height: 100%; border-top-color: transparent; border-bottom-color: tran=
sparent; box-sizing: border-box; }

.vsp_ads .richImage .captionContainer .cbt { font: 13px/13px var(--bing-smt=
c-text-style-default-regular-font-family); color: rgb(210, 208, 206); }

.b_dark .vsp_ads .richImage .captionContainer .cbt { color: rgb(210, 208, 2=
06); }

#detailPage .insights .vsp_ads_c { overflow: hidden; margin-bottom: 20px; m=
argin-top: -5px; }

#detailPage .insights .vsp_ads_c .carousel { border-bottom: 1px solid rgb(1=
70, 170, 170); padding-bottom: 10px; }

#detailPage .insights .vsp_ads_c .carousel .carousel-title-row { font-weigh=
t: bold; line-height: 20px; color: rgb(204, 204, 204); margin-bottom: 10px;=
 }

.insights .vsp_ads_c .carousel-content { display: inline-block; }

.insights .vsp_ads_c .carousel-scroll-content { margin-left: 0px; overflow-=
y: hidden; }

div.insights .vsp_ads_c .carousel .items { white-space: nowrap; border: 0px=
; padding: 0px; }

.insights .vsp_ads_c .carousel .item { margin-right: 8px; display: inline-b=
lock; vertical-align: top; width: 180px; }

.vsp_ads .richImage:focus-within { outline-style: auto; }

.vsp_ads .header { padding: 8px 12px 5px 2px; font-weight: 700; color: rgb(=
237, 235, 233); background-color: rgba(255, 255, 255, 0); }

.vsp_ads .richImage { position: relative; overflow: visible; vertical-align=
: top; border-radius: 4px; background-color: rgb(255, 255, 255); box-shadow=
: rgba(0, 0, 0, 0.05) 0px 0px 0px 1px, rgba(0, 0, 0, 0.1) 0px 2px 3px 0px; =
width: 100%; height: 100%; color: rgb(68, 68, 68); line-height: 17px; }

.vsp_ads .richImage .captionContainer { padding: 8px; font-size: 11px; line=
-height: 16px; overflow: hidden; text-overflow: ellipsis; width: 100%; box-=
sizing: border-box; }

.vsp_ads_c .richImage .captionContainer a { color: rgb(68, 68, 68); white-s=
pace: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 11px; }

.vsp_ads_c .richImage .captionContainer .titl { overflow: hidden; text-over=
flow: ellipsis; white-space: nowrap; }

.vsp_ads_c .richImage .captionContainer .titl.nocb { overflow: hidden; text=
-overflow: ellipsis; text-wrap: wrap; display: -webkit-box; -webkit-line-cl=
amp: 2; -webkit-box-orient: vertical; }

#detailPage .richImage .captionContainer.twolines .titl, #detailPage .richI=
mage .captionContainer.twolines a.tit { white-space: normal; display: -webk=
it-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; max-height: 36=
px; }

#detailPage .richImage .captionContainer.fixh.twolines .titl, #detailPage .=
richImage .captionContainer.fixh.twolines a.tit { height: 36px; }

#detailPage .richImage .captionContainer.twolines { height: auto; }

.vsp_ads_c .richImage .captionContainer .price_c > div { display: inline; }

.vsp_ads_c .richImage .captionContainer .price { font-size: 13px; line-heig=
ht: 17px; }

.vsp_ads_c #ads_units .richImage .captionContainer .price.curr { color: rgb=
(17, 17, 17); font-weight: bold; }

.vsp_ads_c .richImage .captionContainer .price.pre, #p_results .vsp_ads_c .=
richImage .captionContainer .price.pre { color: rgb(118, 118, 118); font-we=
ight: normal; text-decoration: line-through; margin-left: 10px; }

.vsp_ads_c .richImage .captionContainer .shipping { height: 16px; }

.vsp_ads_c .richImage .overlayContainer .ads_dis { position: absolute; top:=
 8px; left: 8px; display: block; color: rgb(102, 102, 102); background-colo=
r: rgb(245, 245, 245); border-radius: 2px; font-size: 11px; text-transform:=
 capitalize; padding: 0px 8px; height: 18px; line-height: 18px; box-shadow:=
 rgba(0, 0, 0, 0.1) 0px 1px 2px 0px; }

.insights .vsp_ads_c .carousel-controls .nav_container { height: 48px; widt=
h: 25px; position: absolute; cursor: pointer; z-index: 1; background-color:=
 transparent; display: none; }

#detailPage:not(.oneCol) .insights .vsp_ads_c .carousel-controls .nav_conta=
iner { top: 90px; }

#detailPage .insights .vsp_ads_c .vpt .carousel-controls .nav_container { d=
isplay: none; }

.insights .vsp_ads_c .carousel:hover .carousel-controls .nav_container { di=
splay: inline-block; }

#detailPage:not(.oneCol) .insights .vsp_ads_c .carousel-controls .nav_right=
 { right: 10px; }

#detailPage:not(.oneCol) .insights .vsp_ads_c .carousel-controls .nav_left =
{ left: 10px; }

#detailPage.rtl:not(.oneCol) .insights .vsp_ads_c .carousel-controls .nav_r=
ight { right: unset; left: 10px; }

#detailPage.rtl:not(.oneCol) .insights .vsp_ads_c .carousel-controls .nav_l=
eft { left: unset; right: 10px; }

.oneCol .insights .vsp_ads_c .carousel-controls .nav_container { left: 50%;=
 margin-top: 60px; }

.oneCol .insights .vsp_ads_c .carousel-controls .nav_right { margin-left: 2=
35px; }

