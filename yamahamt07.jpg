.citm3 .carousel .item .card a, .citm2 .carousel .item .card a { display: f=
lex; flex-direction: column-reverse; }

.citm3 .carousel .item .card a .tit, .citm2 .carousel .item .card a .tit { =
white-space: normal; height: 25px; overflow: hidden; -webkit-box-orient: ho=
rizontal; font-size: 14px; }

.citm3 .carousel .item .card a .tit strong, .citm2 .carousel .item .card a =
.tit strong { font: 700 14px Roboto, Helvetica, sans-serif; }

.citm3 .carousel .item .card a .cardImage, .citm2 .carousel .item .card a .=
cardImage { padding-left: 8px; }

.citm3 a .cardInfo .tit::before, .citm2 a .cardInfo .tit::before { display:=
 block; width: 16px; height: auto; margin: 2px; background-size: cover; }

.citm3 a .cardInfo .tit .magnGlass, .citm2 a .cardInfo .tit .magnGlass { wi=
dth: 16px; height: 16px; margin: 2px 8px 2px 2px; background-size: cover; b=
ackground-repeat: no-repeat; }

.citm3 a .cardInfo .tit::before, .citm2 a .cardInfo .tit::before { margin-r=
ight: 8px; }

.citm3 .carousel .item .card a .tit { padding-left: 17px; padding-top: 8px;=
 }

.citm3 a .cardInfo .tit::before { margin-right: 8px; }

.citm3 a .cardImage .cico { width: 232px !important; height: 80px !importan=
t; }

.citm3 a .cardImage .cico img { width: 232px !important; height: 80px !impo=
rtant; }

.citm2 .carousel .item .card a .tit { padding-left: 12px; padding-top: 8px;=
 }

