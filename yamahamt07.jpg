nter; transform: scale(0); display: none; position: absolute; background-co=
lor: rgb(255, 255, 255); border-radius: var(--bing-ads-smtc-ad-slug-corner)=
; padding: 4px 0px; margin: 18px 0px 0px -17px; box-shadow: rgba(0, 0, 0, 0=
.14) 0px 4px 12px 1px; height: auto; overflow-y: unset; min-width: 120px; }

#b-scopeListItem-menu .b_sp_over_item { font-weight: normal; font-size: 13p=
